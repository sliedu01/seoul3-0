generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Program {
  id          String             @id @default(cuid())
  name        String
  description String?
  coreGoals   String?
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  sessions    ProgramSession[]
  templates   QuestionTemplate[]
}

model Partner {
  id                   String           @id @default(cuid())
  name                 String
  contactName          String?
  contactPhone         String?
  contactEmail         String?
  address              String?
  businessRegistration String?
  contractFile         String?
  contractFile2        String?
  contractFile3        String?
  contractFile4        String?
  contractFile5        String?
  insuranceFile        String?
  bankbookFile         String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  preInspectionFile    String?
  sessions             ProgramSession[]
}

model ProgramSession {
  id                  String             @id @default(cuid())
  programId           String
  partnerId           String?
  sessionNumber       Int
  date                DateTime
  startTime           DateTime?
  endTime             DateTime?
  courseName          String?
  instructorName      String?
  capacity            Int                @default(0)
  participantCount    Int                @default(0)
  completerCount      Int                @default(0)
  resultPdfPath       String?
  resultGoogleFormUrl String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  classDays           ClassDay[]
  facilityCheck       FacilityChecklist?
  partner             Partner?           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  program             Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  surveyDocuments     SurveyDocument[]
  responses           SurveyResponse[]
}

model ClassDay {
  id               String         @id @default(cuid())
  programSessionId String
  date             DateTime
  startTime        DateTime?
  endTime          DateTime?
  title            String?
  capacity         Int            @default(0)
  participantCount Int            @default(0)
  order            Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  session          ProgramSession @relation(fields: [programSessionId], references: [id], onDelete: Cascade)
}

model FacilityChecklist {
  id               String         @id @default(cuid())
  programSessionId String         @unique
  data             String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  session          ProgramSession @relation(fields: [programSessionId], references: [id], onDelete: Cascade)
}

model QuestionTemplate {
  id            String           @id @default(cuid())
  name          String
  type          String
  subType       String?
  scope         String
  description   String?
  googleFormUrl String?
  programId     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  questions     Question[]
  program       Program?         @relation(fields: [programId], references: [id], onDelete: Cascade)
  responses     SurveyResponse[]
}

model Question {
  id         String           @id @default(cuid())
  templateId String
  category   String
  type       String
  growthType String?
  content    String
  order      Int              @default(0)
  answers    Answer[]
  template   QuestionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model SurveyResponse {
  id               String            @id @default(cuid())
  programSessionId String
  templateId       String?
  respondentId     String
  researchTarget   String?
  type             String
  createdAt        DateTime          @default(now())
  answers          Answer[]
  session          ProgramSession    @relation(fields: [programSessionId], references: [id], onDelete: Cascade)
  template         QuestionTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Answer {
  id         String         @id @default(cuid())
  responseId String
  questionId String
  score      Int?
  preScore   Int?
  postChange Int?
  text       String?
  question   Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model MeetingMinute {
  id             String   @id @default(cuid())
  title          String
  date           DateTime
  sequenceNumber Int      @default(1)
  managedOrg     String?
  attendees      String?
  purpose        String?
  agenda         String?
  preparation    String?
  nextSchedule   String?
  meetingContent String?  @default("")
  others         String?
  pdfFilePath    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  location       String?
  time           String?
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String?
  role       Role     @default(MEMBER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    String?
  isApproved Boolean  @default(false)
  phone      String?
}

model OtherSchedule {
  id        String    @id @default(cuid())
  title     String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model FileStorage {
  id        String   @id @default(cuid())
  fileName  String   @unique
  data      Bytes
  mimeType  String
  createdAt DateTime @default(now())
  fileSize  Int?
  sha256    String?
}

model SurveyDocument {
  id               String         @id @default(cuid())
  programSessionId String
  type             String
  category         String
  fileName         String?
  googleFormUrl    String?
  description      String?
  uploadedAt       DateTime       @default(now())
  session          ProgramSession @relation(fields: [programSessionId], references: [id], onDelete: Cascade)
}

model BudgetCategory {
  id           String           @id @default(cuid())
  parentId     String?
  level        Int
  name         String
  budgetAmount BigInt           @default(0)
  order        Int              @default(0)
  isRate       Boolean          @default(false)
  ratePercent  Float?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  parent       BudgetCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     BudgetCategory[] @relation("CategoryTree")
  expenditures Expenditure[]
}

model Expenditure {
  id               String         @id @default(cuid())
  categoryId       String
  subDetailName    String?        // 세세목 명칭 (직접 입력)
  executionDate    DateTime?
  supplyAmount     BigInt         @default(0)
  taxAmount        BigInt         @default(0)
  totalAmount      BigInt         @default(0)
  purpose          String?
  evidenceType     String?
  evidenceFileId   String?
  evidenceFileName String?
  originalFileName String?
  memo             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  category         BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  OPERATOR
  MEMBER
}
